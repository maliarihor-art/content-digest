# Copy to .env and fill values. Never commit .env.

# Google Gemini API key for the serverless digest proxy (api/digest.ts).
# Free tier, no credit card: https://aistudio.google.com/apikey
# In production set as a Vercel project secret — never committed, never sent to
# the browser (ADR 003 / ADR 004).
GEMINI_API_KEY=

# Optional: override the default Gemini model (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash-lite
